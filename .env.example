# hindsight-auth-proxy environment variables
# Copy to .env (gitignored) and fill in real values.
# In Railway, set these as service variables.

# ── Tailscale (production) ────────────────────────────────────────────────────
# Non-ephemeral reusable auth key from https://login.tailscale.com/admin/settings/keys
# Tag the key so the node can be identified: tag:ai-memory
TS_AUTHKEY=tskey-auth-...

# MagicDNS hostname this proxy registers as. Dev: ai-memory-dev, prod: ai-memory
TS_HOSTNAME=ai-memory-dev

# Mount a Railway volume here so the node retains its stable identity across restarts.
TS_STATE_DIR=/var/lib/tailscale

# false = stable MagicDNS name (recommended); true = ephemeral (removed when offline)
TS_EPHEMERAL=false

# ── Listener ──────────────────────────────────────────────────────────────────
LISTEN_PORT=8888

# ── Upstream Hindsight ────────────────────────────────────────────────────────
# Dev:  http://hindsight-dev.baiji-cloud.ts.net:8888  (dialed via ts.Dial over tailnet)
# Prod: http://hindsight.baiji-cloud.ts.net:8888
HINDSIGHT_UPSTREAM_URL=http://hindsight-dev.baiji-cloud.ts.net:8888

# Shared bearer secret; must match HINDSIGHT_API_TENANT_API_KEY and
# HINDSIGHT_API_MCP_AUTH_TOKEN on the upstream Hindsight instance.
# Generate: openssl rand -hex 32
HINDSIGHT_UPSTREAM_TOKEN=<UPSTREAM_SECRET>

# ── ACL source ────────────────────────────────────────────────────────────────
# Primary (Railway): load the ACL from an S3 bucket at boot. Set ACL_S3_BUCKET
# to enable S3 mode; on Railway, wire these to the bucket via Variable References:
#   ACL_S3_ENDPOINT=${{<Bucket>.ENDPOINT}}          # e.g. https://storage.railway.app
#   ACL_S3_BUCKET=${{<Bucket>.BUCKET}}
#   ACL_S3_KEY=acl.yaml
#   ACL_S3_REGION=${{<Bucket>.REGION}}
#   ACL_S3_ACCESS_KEY_ID=${{<Bucket>.ACCESS_KEY_ID}}
#   ACL_S3_SECRET_ACCESS_KEY=${{<Bucket>.SECRET_ACCESS_KEY}}
# ACL_S3_USE_PATH_STYLE=false  # false for Railway (virtual-hosted); true for path-style MinIO
ACL_S3_ENDPOINT=
ACL_S3_BUCKET=
ACL_S3_KEY=acl.yaml
ACL_S3_ACCESS_KEY_ID=
ACL_S3_SECRET_ACCESS_KEY=
#
# Fallback (local dev / tests): a YAML file on disk, used only when ACL_S3_BUCKET is empty.
ACL_FILE=/app/acl.yaml

# ── Dev mode (local testing only) ─────────────────────────────────────────────
# When set, the proxy skips tsnet entirely (plain TCP listener) and reads the
# caller's email from this HTTP request header. TS_HOSTNAME and TS_AUTHKEY
# are not required in this mode.
#
# Example (run with a local Hindsight on :8888):
#   DEV_IDENTITY_HEADER=X-Dev-User HINDSIGHT_UPSTREAM_URL=http://localhost:8888 \
#   HINDSIGHT_UPSTREAM_TOKEN=test ACL_FILE=./acl.yaml.example LISTEN_PORT=9090 \
#   go run .
#
# Then test:
#   curl -H 'X-Dev-User: alice@brickeye.com' localhost:9090/mcp/hermes-alice/
#   curl -H 'X-Dev-User: alice@brickeye.com' localhost:9090/mcp/hermes-bob/   # → 403
DEV_IDENTITY_HEADER=
